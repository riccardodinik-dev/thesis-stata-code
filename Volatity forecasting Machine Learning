      "cell_type": "markdown",
      "source": [
        "We now create calendar features."
      ],
      "metadata": {
        "id": "xv-LuZYyHGP5"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "df['days_from_start'] = (df['ds'] - df['ds'].min()).dt.days\n",
        "df['day_of_week']     = df['ds'].dt.dayofweek          # 0 = Monday\n",
        "df['day_of_month']    = df['ds'].dt.day\n",
        "df['week_of_year']    = df['ds'].dt.isocalendar().week.astype(int)"
      ],
      "metadata": {
        "id": "UtQEEd7Xy9u4"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Now we can create our numerical features relying on our log transformations."
      ],
      "metadata": {
        "id": "MggpQUlhWViH"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "lags = [1, 5, 10, 22]\n",
        "for lag in lags:\n",
        "    df[f'lag_log_rv5_var_{lag}'] = (df['log_rv5_var']).shift(lag)\n",
        "    df[f'lag_log_vix_squared_{lag}'] = df['log_vix_squared'].shift(lag)"
      ],
      "metadata": {
        "id": "B4FopeKD2V1C"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
