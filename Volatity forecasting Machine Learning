      "cell_type": "markdown",
      "source": [
        "*Calculate epsilons.*"
      ],
      "metadata": {
        "id": "KUISSjdnb4oi"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "df['expanding_mean'] = df['sp500_ret'].expanding().mean().shift(1)"
      ],
      "metadata": {
        "id": "L4iiAAwYpBUz"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "df['epsilon'] = (df['sp500_ret'] - df['expanding_mean'])"
      ],
      "metadata": {
        "id": "HSBchiArb1bl"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "df = df.dropna().reset_index(drop=True)"
      ],
      "metadata": {
        "id": "YADKXLzSOIH7"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Create two dataframes: one for the TS models, one for the ML models."
      ],
      "metadata": {
        "id": "xXQo1eF9clIn"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "advanced_df = df[['ds', 'epsilon', 'rv5_var']] #for the time series models\n",
        "df = df[['ds', 'rv5_var','vix_squared']] #for the machine learning models"
      ],
      "metadata": {
        "id": "RFU8xRQFx_JC"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "For sake of comparison with the ML models we need to have same length for the two df's."
      ],
      "metadata": {
        "id": "LDGT6gIGc7R7"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "uniform_date = '1996-02-05'"
