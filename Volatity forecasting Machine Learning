      "metadata": {
        "id": "9x2UjgOjTt7N"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "advanced_df = advanced_df.loc[advanced_df['ds'] >= uniform_date].reset_index(drop=True)"
